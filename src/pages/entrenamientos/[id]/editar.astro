---
import AppLayout from '../../../layouts/AppLayout.astro';
import { getSessionToken, clearSessionCookie } from '../../../lib/auth';
import { apiFetch, ApiError } from '../../../lib/api-client';
import {
    procesarFormularioEntrenamiento,
    type EjercicioElegido,
    type FormularioEntrenamiento,
    type ResultadoBusqueda,
} from '../../../lib/entrenamiento-form';

const token = getSessionToken(Astro.cookies)!;
const { id } = Astro.params;

interface Entrenamiento {
    _id: string;
    fecha: string;
    hora: string;
    estado: 'pendiente' | 'completado';
    notasGenerales?: string;
    ejercicios: {
        exerciseId: string;
        nombre: string;
        series: number;
        repeticiones: number;
        peso: number;
        completado: boolean;
        notaPersonal?: string;
    }[];
}

let errorMessage: string | null = null;
let busquedaError: string | null = null;
let fecha = '';
let hora = '';
let notasGenerales = '';
let entrenamientoCompletado = false;
let q = '';
let ejerciciosElegidos: EjercicioElegido[] = [];
let resultadosBusqueda: ResultadoBusqueda[] = [];

if (Astro.request.method === 'POST') {
    const formData = await Astro.request.formData();
    entrenamientoCompletado = formData.get('entrenamientoCompletado') === 'on';

    let estado: FormularioEntrenamiento;
    try {
        estado = await procesarFormularioEntrenamiento(formData, token);
    } catch (e) {
        if (e instanceof ApiError && e.statusCode === 401) {
            clearSessionCookie(Astro.cookies);
            return Astro.redirect('/login');
        }
        throw e;
    }

    ({ fecha, hora, notasGenerales, q, ejerciciosElegidos, resultadosBusqueda, busquedaError } = estado);

    if (formData.has('guardar')) {
        if (estado.erroresValidacion.length === 0) {
            try {
                await apiFetch(`/api/entrenamientos/${id}`, {
                    method: 'PUT',
                    token,
                    body: {
                        fecha,
                        hora,
                        estado: entrenamientoCompletado ? 'completado' : 'pendiente',
                        notasGenerales,
                        ejercicios: ejerciciosElegidos.map((e) => ({
                            exerciseId: e.exerciseId,
                            nombre: e.nombre,
                            series: e.series,
                            repeticiones: e.repeticiones,
                            peso: e.peso,
                            completado: e.completado,
                            notaPersonal: e.notaPersonal,
                        })),
                    },
                });
                return Astro.redirect('/entrenamientos');
            } catch (e) {
                if (e instanceof ApiError && e.statusCode === 401) {
                    clearSessionCookie(Astro.cookies);
                    return Astro.redirect('/login');
                }
                errorMessage = e instanceof Error ? e.message : 'Error desconocido';
            }
        } else {
            errorMessage = estado.erroresValidacion.join('. ');
        }
    }
} else {
    let entrenamiento: Entrenamiento | null = null;
    try {
        entrenamiento = await apiFetch<Entrenamiento>(`/api/entrenamientos/${id}`, { token });
    } catch (e) {
        if (e instanceof ApiError && e.statusCode === 401) {
            clearSessionCookie(Astro.cookies);
            return Astro.redirect('/login');
        }
        return Astro.redirect('/entrenamientos?error=' + encodeURIComponent('Entrenamiento no encontrado'));
    }

    fecha = entrenamiento.fecha.slice(0, 10);
    hora = entrenamiento.hora;
    notasGenerales = entrenamiento.notasGenerales ?? '';
    entrenamientoCompletado = entrenamiento.estado === 'completado';
    ejerciciosElegidos = entrenamiento.ejercicios.map((ej) => ({
        exerciseId: ej.exerciseId,
        nombre: ej.nombre,
        series: ej.series,
        repeticiones: ej.repeticiones,
        peso: ej.peso,
        completado: ej.completado,
        notaPersonal: ej.notaPersonal ?? '',
    }));
}
---
<AppLayout title="Editar entrenamiento">
    <div class="max-w-2xl bg-white rounded-lg shadow p-6">
        <h1 class="text-2xl font-bold mb-4">Editar entrenamiento</h1>

        {errorMessage && <p class="text-red-600 mb-3">{errorMessage}</p>}

        <form method="POST" class="flex flex-col gap-4">
            <div class="border rounded p-3">
                <label class="text-sm text-gray-600">Buscar ejercicio</label>
                <div class="flex gap-2 mt-1">
                    <input type="text" name="q" value={q} class="border rounded px-3 py-2 flex-1" placeholder="ej. press de banca" />
                    <button type="submit" name="buscar" value="1" class="bg-gray-800 text-white rounded px-3 py-2">Buscar</button>
                </div>

                {busquedaError && <p class="text-red-600 text-sm mt-2">{busquedaError}</p>}

                {resultadosBusqueda.length > 0 && (
                    <ul class="mt-3 flex flex-col gap-2">
                        {resultadosBusqueda
                            .filter((r) => !ejerciciosElegidos.some((e) => e.exerciseId === r.exerciseId))
                            .map((r) => (
                                <li class="flex items-center justify-between border rounded px-3 py-2">
                                    <span>{r.name}</span>
                                    <button type="submit" name="agregar" value={`${r.exerciseId}::${r.name}`} class="text-blue-600 text-sm">Agregar</button>
                                </li>
                            ))}
                    </ul>
                )}
            </div>

            <div class="flex gap-3">
                <label class="text-sm text-gray-600 flex-1">
                    Fecha
                    <input type="date" name="fecha" required value={fecha} class="border rounded px-3 py-2 w-full" />
                </label>
                <label class="text-sm text-gray-600 flex-1">
                    Hora
                    <input type="time" name="hora" required value={hora} class="border rounded px-3 py-2 w-full" />
                </label>
            </div>

            <label class="text-sm text-gray-600">
                Notas generales (opcional)
                <textarea name="notasGenerales" class="border rounded px-3 py-2 w-full">{notasGenerales}</textarea>
            </label>

            <label class="flex items-center gap-2 text-sm text-gray-600">
                <input type="checkbox" name="entrenamientoCompletado" checked={entrenamientoCompletado} />
                Marcar entrenamiento como completado
            </label>

            {ejerciciosElegidos.map((ej, i) => (
                <div class="border rounded p-3 flex flex-col gap-2">
                    <input type="hidden" name={`ej_${i}_exerciseId`} value={ej.exerciseId} />
                    <input type="hidden" name={`ej_${i}_nombre`} value={ej.nombre} />
                    <div class="flex items-center justify-between">
                        <strong>{ej.nombre}</strong>
                        <button type="submit" name="quitar" value={ej.exerciseId} class="text-red-600 text-sm">Quitar</button>
                    </div>
                    <div class="flex gap-2">
                        <label class="text-xs text-gray-600">
                            Series
                            <input type="number" name={`ej_${i}_series`} min="1" required value={ej.series} class="border rounded px-2 py-1 w-full" />
                        </label>
                        <label class="text-xs text-gray-600">
                            Repeticiones
                            <input type="number" name={`ej_${i}_repeticiones`} min="1" required value={ej.repeticiones} class="border rounded px-2 py-1 w-full" />
                        </label>
                        <label class="text-xs text-gray-600">
                            Peso (kg)
                            <input type="number" name={`ej_${i}_peso`} min="0" required value={ej.peso} class="border rounded px-2 py-1 w-full" />
                        </label>
                    </div>
                    <label class="text-xs text-gray-600">
                        Nota personal (opcional)
                        <input type="text" name={`ej_${i}_notaPersonal`} value={ej.notaPersonal} class="border rounded px-2 py-1 w-full" />
                    </label>
                    <label class="flex items-center gap-2 text-xs text-gray-600">
                        <input type="checkbox" name={`ej_${i}_completado`} checked={ej.completado} />
                        Completado
                    </label>
                </div>
            ))}

            <button type="submit" name="guardar" value="1" class="bg-blue-600 text-white rounded px-3 py-2">Guardar cambios</button>
        </form>
    </div>
</AppLayout>
