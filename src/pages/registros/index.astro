---
import AppLayout from '../../layouts/AppLayout.astro';
import { getSessionToken, clearSessionCookie } from '../../lib/auth';
import { apiFetch, ApiError } from '../../lib/api-client';

const token = getSessionToken(Astro.cookies)!;

if (Astro.request.method === 'POST') {
    const formData = await Astro.request.formData();
    const id = String(formData.get('id') ?? '');

    try {
        await apiFetch(`/api/registros-diarios/${id}`, { method: 'DELETE', token });
        return Astro.redirect('/registros');
    } catch (e) {
        if (e instanceof ApiError && e.statusCode === 401) {
            clearSessionCookie(Astro.cookies);
            return Astro.redirect('/login');
        }
        const message = e instanceof Error ? e.message : 'Error desconocido';
        return Astro.redirect(`/registros?error=${encodeURIComponent(message)}`);
    }
}

interface RegistroDiario {
    _id: string;
    fecha: string;
    nivelEnergia: number;
    habitosCompletados: { habito: string; completado: boolean }[];
}

let registros: RegistroDiario[] = [];
let errorMessage = Astro.url.searchParams.get('error');

try {
    registros = await apiFetch<RegistroDiario[]>('/api/registros-diarios', { token });
    registros.sort((a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime());
} catch (e) {
    if (e instanceof ApiError && e.statusCode === 401) {
        clearSessionCookie(Astro.cookies);
        return Astro.redirect('/login');
    }
    errorMessage = e instanceof Error ? e.message : 'Error desconocido';
}
---
<AppLayout title="Registros diarios">
    <div class="flex items-center justify-between mb-4">
        <h1 class="text-2xl font-bold">Registros diarios</h1>
        <a href="/registros/nuevo" class="bg-blue-600 text-white rounded px-3 py-2">+ Nuevo registro</a>
    </div>

    {errorMessage && <p class="text-red-600 mb-3">{errorMessage}</p>}

    <table class="w-full bg-white rounded-lg shadow overflow-hidden">
        <thead class="bg-gray-100 text-left">
            <tr>
                <th class="p-3">Fecha</th>
                <th class="p-3">Nivel de energía</th>
                <th class="p-3">Hábitos completados</th>
                <th class="p-3">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {registros.map((registro) => {
                const completados = registro.habitosCompletados.filter((hc) => hc.completado).length;
                const total = registro.habitosCompletados.length;
                return (
                    <tr>
                        <td class="p-3">{new Date(registro.fecha).toLocaleDateString('es-MX', { timeZone: 'UTC' })}</td>
                        <td class="p-3">{registro.nivelEnergia} / 5</td>
                        <td class="p-3">{completados} / {total}</td>
                        <td class="p-3 flex gap-2">
                            <a href={`/registros/${registro._id}/editar`} class="text-blue-600">Editar</a>
                            <form method="POST" class="confirmar-eliminar">
                                <input type="hidden" name="id" value={registro._id} />
                                <button type="submit" class="text-red-600">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                );
            })}
        </tbody>
    </table>

    <script>
        document.querySelectorAll('.confirmar-eliminar').forEach((form) => {
            form.addEventListener('submit', (event) => {
                if (!confirm('¿Eliminar este registro? Esta acción no se puede deshacer.')) {
                    event.preventDefault();
                }
            });
        });
    </script>
</AppLayout>
