---
import '../styles/global.css';
---
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <title>WellSync — Recuperar contraseña</title>
    </head>
    <body class="min-h-screen flex items-center justify-center bg-gray-50">
        <div class="w-full max-w-sm p-6 bg-white rounded-lg shadow">
            <h1 class="text-2xl font-bold mb-4">Recuperar contraseña</h1>
            <p class="text-sm text-gray-600 mb-4">Ingresa tu correo y te enviaremos un enlace para restablecer tu contraseña.</p>

            <form id="forgot-form" class="flex flex-col gap-3">
                <input type="email" name="email" placeholder="Correo" required class="border rounded px-3 py-2" />
                <button type="submit" class="bg-blue-600 text-white rounded px-3 py-2">Enviar enlace</button>
            </form>

            <p id="forgot-error" class="text-red-600 mt-2 hidden"></p>
            <p id="forgot-success" class="text-green-600 mt-2 hidden"></p>

            <div class="mt-4 text-center text-sm">
                <a href="/login" class="text-blue-600 hover:underline">Volver a iniciar sesión</a>
            </div>
        </div>

        <script>
            const form = document.getElementById('forgot-form');
            const errorEl = document.getElementById('forgot-error');
            const successEl = document.getElementById('forgot-success');
            const submitBtn = form.querySelector('button[type="submit"]');

            function showError(message) {
                errorEl.textContent = message;
                errorEl.classList.remove('hidden');
                successEl.classList.add('hidden');
            }

            function showSuccess(message) {
                successEl.textContent = message;
                successEl.classList.remove('hidden');
                errorEl.classList.add('hidden');
            }

            form.addEventListener('submit', async (event) => {
                event.preventDefault();
                errorEl.classList.add('hidden');
                successEl.classList.add('hidden');
                submitBtn.disabled = true;
                submitBtn.textContent = 'Enviando...';

                const formData = new FormData(form);
                const email = formData.get('email');

                try {
                    const response = await fetch('/api/forgot-password', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email }),
                    });

                    let data;
                    try {
                        data = await response.json();
                    } catch {
                        showError('Error del servidor. Intenta de nuevo más tarde.');
                        submitBtn.disabled = false;
                        submitBtn.textContent = 'Enviar enlace';
                        return;
                    }

                    if (data.success) {
                        showSuccess('Si el email está registrado, recibirás un enlace de recuperación.');
                    } else {
                        showError(data.message ?? 'No se pudo procesar la solicitud');
                    }
                } catch {
                    showError('Error de conexión. Verifica tu internet e intenta de nuevo.');
                }

                submitBtn.disabled = false;
                submitBtn.textContent = 'Enviar enlace';
            });
        </script>
    </body>
</html>
