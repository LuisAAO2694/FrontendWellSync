---
import '../styles/global.css';

const token = Astro.url.searchParams.get('token');
---
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <title>WellSync — Restablecer contraseña</title>
    </head>
    <body class="min-h-screen flex items-center justify-center bg-gray-50">
        <div class="w-full max-w-sm p-6 bg-white rounded-lg shadow">
            <h1 class="text-2xl font-bold mb-4">Restablecer contraseña</h1>

            {token ? (
                <>
                    <p class="text-sm text-gray-600 mb-4">Ingresa tu nueva contraseña.</p>

                    <form id="reset-form" class="flex flex-col gap-3">
                        <input type="password" name="password" placeholder="Nueva contraseña" required minlength="8" class="border rounded px-3 py-2" />
                        <input type="password" name="confirmar" placeholder="Confirmar contraseña" required minlength="8" class="border rounded px-3 py-2" />
                        <button type="submit" class="bg-blue-600 text-white rounded px-3 py-2">Restablecer</button>
                    </form>

                    <p id="reset-error" class="text-red-600 mt-2 hidden"></p>
                    <p id="reset-success" class="text-green-600 mt-2 hidden"></p>
                </>
            ) : (
                <p class="text-red-600">Enlace inválido o expirado. Solicita un nuevo enlace de recuperación.</p>
            )}

            <div class="mt-4 text-center text-sm">
                <a href="/login" class="text-blue-600 hover:underline">Volver a iniciar sesión</a>
            </div>
        </div>

        <script>
            const form = document.getElementById('reset-form');
            if (form) {
                const errorEl = document.getElementById('reset-error');
                const successEl = document.getElementById('reset-success');
                const submitBtn = form.querySelector('button[type="submit"]');

                function showError(message) {
                    errorEl.textContent = message;
                    errorEl.classList.remove('hidden');
                    successEl.classList.add('hidden');
                }

                function showSuccess(message) {
                    successEl.textContent = message;
                    successEl.classList.remove('hidden');
                    errorEl.classList.add('hidden');
                }

                form.addEventListener('submit', async (event) => {
                    event.preventDefault();
                    errorEl.classList.add('hidden');
                    successEl.classList.add('hidden');

                    const formData = new FormData(form);
                    const password = formData.get('password');
                    const confirmar = formData.get('confirmar');

                    if (password !== confirmar) {
                        showError('Las contraseñas no coinciden');
                        return;
                    }

                    submitBtn.disabled = true;
                    submitBtn.textContent = 'Restableciendo...';

                    const params = new URLSearchParams(window.location.search);
                    const token = params.get('token');

                    try {
                        const response = await fetch('/api/reset-password', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ token, password }),
                        });

                        let data;
                        try {
                            data = await response.json();
                        } catch {
                            showError('Error del servidor. Intenta de nuevo.');
                            submitBtn.disabled = false;
                            submitBtn.textContent = 'Restablecer';
                            return;
                        }

                        if (data.success) {
                            showSuccess('Contraseña actualizada. Redirigiendo al inicio de sesión...');
                            setTimeout(() => { window.location.href = '/login'; }, 2000);
                        } else {
                            showError(data.message ?? 'No se pudo restablecer la contraseña');
                        }
                    } catch {
                        showError('Error de conexión. Verifica tu internet e intenta de nuevo.');
                    }

                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Restablecer';
                });
            }
        </script>
    </body>
</html>
