---
import AppLayout from '../../layouts/AppLayout.astro';
import { getSessionToken, decodeSessionPayload, clearSessionCookie } from '../../lib/auth';
import { apiFetch, ApiError } from '../../lib/api-client';

const token = getSessionToken(Astro.cookies)!;
const payload = decodeSessionPayload(token);

if (!payload) {
    clearSessionCookie(Astro.cookies);
    return Astro.redirect('/login');
}

interface UsuarioPerfil {
    _id: string;
    nombre: string;
    email: string;
}

let usuario: UsuarioPerfil | null = null;
let errorMessage: string | null = null;

try {
    usuario = await apiFetch<UsuarioPerfil>(`/api/usuarios/${payload.id}`, { token });
} catch (e) {
    if (e instanceof ApiError && e.statusCode === 401) {
        clearSessionCookie(Astro.cookies);
        return Astro.redirect('/login');
    }
    errorMessage = e instanceof Error ? e.message : 'Error desconocido';
}
---
<AppLayout title="Dashboard">
    {errorMessage && <p class="text-red-600">{errorMessage}</p>}
    {usuario && (
        <div class="max-w-md bg-white rounded-lg shadow p-6">
            <h1 class="text-2xl font-bold mb-2">Hola, {usuario.nombre}</h1>
            <p class="text-gray-600">{usuario.email}</p>
        </div>
    )}
</AppLayout>
