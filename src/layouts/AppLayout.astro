---
import '../styles/global.css';
import { getSessionToken, decodeSessionPayload } from '../lib/auth';

interface Props {
    title: string;
}

const { title } = Astro.props;

const token = getSessionToken(Astro.cookies);
const payload = token ? decodeSessionPayload(token) : null;
const esAdmin = payload?.rol === 'administrador';
---
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <title>WellSync — {title}</title>
    </head>
    <body class="min-h-screen bg-gray-50">
        <nav class="bg-white shadow px-6 py-3 flex items-center justify-between">
            <div class="flex gap-4 items-center">
                <span class="font-bold">WellSync</span>
                <a href="/dashboard" class="text-gray-600 hover:text-gray-900">Dashboard</a>
                <a href="/habitos" class="text-gray-600 hover:text-gray-900">Hábitos</a>
                <a href="/registros" class="text-gray-600 hover:text-gray-900">Registros</a>
                <a href="/entrenamientos" class="text-gray-600 hover:text-gray-900">Entrenamientos</a>
                <a href="/perfil" class="text-gray-600 hover:text-gray-900">Mi perfil</a>
                <a href="/logros" class="text-gray-600 hover:text-gray-900">Logros</a>
                <a href="/notificaciones" class="text-gray-600 hover:text-gray-900">Notificaciones</a>
                <a href="/calorias" class="text-gray-600 hover:text-gray-900">Calorías</a>
                <a href="/reportes" class="text-gray-600 hover:text-gray-900">Reportes</a>
                {esAdmin && <a href="/usuarios" class="text-gray-600 hover:text-gray-900">Usuarios</a>}
            </div>
            <form id="logout-form">
                <button type="submit" class="text-gray-600 hover:text-gray-900">Cerrar sesión</button>
            </form>
        </nav>
        <main class="p-6">
            <slot />
        </main>

        <script>
            document.getElementById('logout-form')?.addEventListener('submit', async (event) => {
                event.preventDefault();
                await fetch('/api/logout', { method: 'POST' });
                window.location.href = '/login';
            });
        </script>
    </body>
</html>
