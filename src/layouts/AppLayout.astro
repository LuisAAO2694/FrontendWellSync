---
import '../styles/global.css';
import { getSessionToken, decodeSessionPayload } from '../lib/auth';

interface Props {
    title: string;
}

const { title } = Astro.props;

const token = getSessionToken(Astro.cookies);
const payload = token ? decodeSessionPayload(token) : null;
const esAdmin = payload?.rol === 'administrador';

function esActivo(href: string): boolean {
    const pathname = Astro.url.pathname;
    return pathname === href || pathname.startsWith(`${href}/`);
}

function claseLink(href: string): string {
    return esActivo(href) ? 'text-blue-600 font-semibold' : 'text-gray-600 hover:text-gray-900';
}

const enlaces = [
    { href: '/dashboard', texto: 'Dashboard' },
    { href: '/habitos', texto: 'Hábitos' },
    { href: '/registros', texto: 'Registros' },
    { href: '/entrenamientos', texto: 'Entrenamientos' },
    { href: '/perfil', texto: 'Mi perfil' },
    { href: '/logros', texto: 'Logros' },
    { href: '/notificaciones', texto: 'Notificaciones' },
    { href: '/calorias', texto: 'Calorías' },
    { href: '/reportes', texto: 'Reportes' },
    ...(esAdmin ? [{ href: '/usuarios', texto: 'Usuarios' }] : []),
];
---
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <title>WellSync — {title}</title>
    </head>
    <body class="min-h-screen bg-gray-50">
        <nav class="bg-white shadow px-6 py-3 flex items-center justify-between">
            <div class="flex gap-4 items-center">
                <span class="font-bold">WellSync</span>
                {enlaces.map((enlace) => (
                    <a href={enlace.href} class={claseLink(enlace.href)} aria-current={esActivo(enlace.href) ? 'page' : undefined}>
                        {enlace.texto}
                    </a>
                ))}
            </div>
            <form id="logout-form">
                <button type="submit" class="text-gray-600 hover:text-gray-900">Cerrar sesión</button>
            </form>
        </nav>
        <main class="p-6">
            <slot />
        </main>

        <script>
            document.getElementById('logout-form')?.addEventListener('submit', async (event) => {
                event.preventDefault();
                await fetch('/api/logout', { method: 'POST' });
                window.location.href = '/login';
            });
        </script>
    </body>
</html>
